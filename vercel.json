{
  "functions": {
    "api/index.py": {
      "maxDuration": 300,
      "memory": 1024,
      "includeFiles": "{demo,lambdas}/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "crons": [
    { "path": "/api/purge-expired", "schedule": "0 3 * * *" },
    { "path": "/api/anchor-access-log", "schedule": "5 * * * *" }
  ]
}
