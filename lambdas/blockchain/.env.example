# Xinsere blockchain permission service — local config
# Copy to .env and fill in. .env is gitignored — NEVER commit real values.

# --- Network (defaults are correct for Amoy; override only if needed) ---
XINSERE_RPC_URL=https://rpc-amoy.polygon.technology
XINSERE_CHAIN_ID=80002
XINSERE_CONTRACT_ADDRESS=0xf2978c58Ec46103FC2110575DFd62cf3ba997FCD

# Separate RPC for audit-trail log queries. The write RPC above rejects
# eth_getLogs entirely; drpc.org serves filtered logs in <=10k-block windows.
XINSERE_LOGS_RPC_URL=https://polygon-amoy.drpc.org
XINSERE_LOGS_CHUNK_SIZE=9000

# Anchor block for audit scans — at/just before contract deployment (2026-07-03).
XINSERE_DEPLOY_BLOCK=41330000

# --- Wallet source ---
# The service prefers AWS Secrets Manager (the real, secure path). It only falls
# back to XINSERE_PRIVATE_KEY if the secret cannot be read — handy for quick local
# tests when you don't have AWS creds handy. Leave the private key line commented
# out to force the Secrets Manager path.
XINSERE_SECRET_ID=xinsere/blockchain/polygon-mumbai/private-key
AWS_REGION=us-east-1
# XINSERE_PRIVATE_KEY=0x...   # dev-only fallback; do not use in production

# --- Grantee hashing ---
# granteeHash = HMAC-SHA256(identity, TENANT_SALT). Per-tenant salt prevents
# anyone from inferring an identity from an on-chain hash. Use a real random salt
# per tenant in production; this is a dev default only.
XINSERE_TENANT_SALT=dev-tenant-salt-change-me

# --- Gas (Amoy enforces a >=25 gwei priority fee floor) ---
# Writes fail with "gas price below minimum" if the tip is under 25 gwei.
XINSERE_PRIORITY_FEE_GWEI=30
XINSERE_MAX_FEE_GWEI=50
